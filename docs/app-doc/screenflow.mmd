    LOGIN --> HOME

    HOME["🏠 Home Feed\n(FeedScreen)"] --> ARTICLE["📄 Article Detail"]
    HOME --> SEARCH["🔍 Search & Filter"]
    HOME --> PREFS["⚙️ Feed Preferences"]

    NAV["Bottom Navigation Bar"] --> HOME
    NAV --> MAP
    NAV --> INSIGHTS
    NAV --> CHAT
    NAV --> PROFILE

    MAP["🗺️ Disease Map\n(MapScreen)"] --> MAPDETAIL["📍 Map Detail\n(outbreak info)"]
    MAP -->|15km proximity| ALERT["👻 Ghost Alert Banner\n+ System Notification"]

    INSIGHTS["📊 Insights Screen\n(live charts)"] --> ALERTS["🚨 Alerts Screen"]

    CHAT["💬 Chat List"] --> GROUP["👥 Group Chat"]
