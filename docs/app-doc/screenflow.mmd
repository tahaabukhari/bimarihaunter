    PROFILE["👤 Profile Screen"] --> SETTINGS["⚙️ Settings"]
    PROFILE --> QRCODE["📱 My QR Code\n(shareable UID)"]
    PROFILE -->|No network| OFFLINE["📵 Offline Screen\n(ghost_sleep)"]

